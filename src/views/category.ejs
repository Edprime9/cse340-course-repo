<%- include('partials/header') %>

<main>
  <h1><%= category.name %></h1>

  <p><%= category.description %></p>

  <h2>Projects in this Category</h2>

  <ul class="main-list">
    <% projects.forEach(project => { %>
      <li>
        <a href="/project/<%= project.project_id %>">
          <%= project.title %>
        </a>
      </li>
    <% }) %>
  </ul>
</main>

<%- include('partials/footer') %>